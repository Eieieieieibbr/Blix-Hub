    local scanY = 0
    twinkleConn = RS.RenderStepped:Connect(function(dt)
        t = t + dt
        -- Twinkle stars
        for i, sd in ipairs(starData) do
            local flicker = math.sin(t * (1.5 + i * 0.3) + i) * 0.3
            sd.frame.BackgroundTransparency = math.clamp(sd.base + flicker, 0, 0.95)
