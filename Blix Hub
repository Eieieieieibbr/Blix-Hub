local structDupeGiver    = ""
local structDupeReceiver = ""
local structDupeDoFurni  = true

sDupe:Textbox("Giver Username", function(v) structDupeGiver = v end)
sDupe:Textbox("Receiver Username", function(v) structDupeReceiver = v end)
sDupe:Toggle("Include Furniture", function(v) structDupeDoFurni = v end)

local function placeOneStructure(item, offset, player, woodClass, doRepeat)
    -- Burst fire + repeat until server removes the pending model
    local PlaceRemote = ReplicatedStorage.PlaceStructure.ClientPlacedStructure
    local itemName = item:FindFirstChild("ItemName") and item.ItemName.Value
    if not itemName then return end
    if doRepeat then
        -- fire every task.wait(0) until the model disappears (server accepted)
        repeat
            task.wait(0)
            pcall(function()
                PlaceRemote:FireServer(itemName, offset, player, woodClass, item, true)
                PlaceRemote:FireServer(itemName, offset, player, woodClass, item, true)
                PlaceRemote:FireServer(itemName, offset, player, woodClass, item, true)
            end)
        until not item.Parent
    else
        for i = 1, 10 do
            pcall(function()
                PlaceRemote:FireServer(itemName, offset, player, woodClass, item, true)
            end)
            task.wait(0)
        end
    end
end

sDupe:Button("► Dupe Structures (Fast)", function()
    spawn(function()
        if structDupeGiver == "" or structDupeReceiver == "" then
            Notify("Blix Hub","Set both Giver and Receiver first!",3); return
        end

        -- Find base origin squares
        local GiveOrigin, RecvOrigin
        for _,v in pairs(workspace.Properties:GetDescendants()) do
            if v.Name == "Owner" then
                if tostring(v.Value) == structDupeGiver  then GiveOrigin = v.Parent:FindFirstChild("OriginSquare") end
                if tostring(v.Value) == structDupeReceiver then RecvOrigin = v.Parent:FindFirstChild("OriginSquare") end
            end
        end
        if not GiveOrigin  then Notify("Blix Hub","Giver base not found!",3);    return end
        if not RecvOrigin  then Notify("Blix Hub","Receiver base not found!",3); return end

        local player   = LP
        local structs  = 0
        local furnis   = 0
        local threads  = 0
        local done     = 0

        -- Collect all items first to avoid iterating while spawning
        local toPlace = {}
        for _,v in pairs(workspace.PlayerModels:GetDescendants()) do
            if v.Name == "Owner" and tostring(v.Value) == structDupeGiver then
                local item    = v.Parent
                local typeVal = item:FindFirstChild("Type") and item.Type.Value
                local isStruct = typeVal == "Structure" and (item:FindFirstChildOfClass("Part") or item:FindFirstChildOfClass("WedgePart"))
                local isFurni  = structDupeDoFurni and typeVal == "Furniture" and item:FindFirstChildOfClass("Part")
                if isStruct or isFurni then
                    local mainCF = (item:FindFirstChild("MainCFrame") and item.MainCFrame.Value)
                              or (item:FindFirstChild("Main") and item.Main.CFrame)
                              or (item:FindFirstChildOfClass("Part") and item:FindFirstChildOfClass("Part").CFrame)
                    if mainCF then
                        local newPos = mainCF.Position - GiveOrigin.Position + RecvOrigin.Position
                        local offset = CFrame.new(newPos) * mainCF.Rotation
                        local woodClass = item:FindFirstChild("BlueprintWoodClass") and item.BlueprintWoodClass.Value or nil
                        table.insert(toPlace, {item=item, offset=offset, woodClass=woodClass, isStruct=isStruct})
                        if isStruct then structs = structs + 1 else furnis = furnis + 1 end
                    end
                end
            end
        end

        if #toPlace == 0 then Notify("Blix Hub","No structures found for that player!",3); return end

        Notify("Blix Hub","Placing "..structs.." structures + "..furnis.." furniture in parallel...",3)

        -- Spawn ALL placements at the same time — this is what makes it fast
        for _,data in ipairs(toPlace) do
            threads = threads + 1
            task.spawn(function()
                placeOneStructure(data.item, data.offset, player, data.woodClass, true)
                done = done + 1
            end)
        end

        -- Wait for all threads to finish
        repeat task.wait(0.5) until done >= threads
        Notify("Blix Hub","Structure Dupe done! ("..done.." placed)",3)
    end)
end)

