local function dragItemToSlot(item, slotCF, passes)
    passes = passes or 30
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    -- TP player next to item so server accepts the drag
    if hrp then
        pcall(function() hrp.CFrame = item:GetPivot() * CFrame.new(0, 3, 6) end)
        task.wait(0.15)
    end
    for i = 1, passes do
        Drag:FireServer(item)
        item:PivotTo(slotCF)
        task.wait(0)
    end
end

local function instantTruckLoad(truck, items)
    if not truck.PrimaryPart then truck.PrimaryPart = truck:FindFirstChildOfClass("BasePart") end
    local homeCF = truck:GetPivot()
    local slotCFs = {}

    -- First pass: load every item
    for idx, v in ipairs(items) do
        if not v or not v.Parent then continue end
        local itemCF = (v:FindFirstChild("WoodSection") and v.WoodSection.CFrame) or v:GetPivot()
        local slotCF = homeCF * CFrame.new(0, 2 + (idx-1) * 0.6, 0)
        slotCFs[v] = slotCF

        -- TP truck to item
        for i = 1, 8 do Drag:FireServer(truck); truck:PivotTo(itemCF); task.wait(0) end
        -- Grab item to slot
        dragItemToSlot(v, slotCF, 30)
        -- Restore truck home
        for i = 1, 8 do Drag:FireServer(truck); truck:PivotTo(homeCF); task.wait(0) end
    end

    -- Retry loop: keep going until every item is within 15 studs of its slot (max 3 passes)
    for pass = 1, 3 do
        task.wait(1.5)
        local missed = {}
        for _, v in ipairs(items) do
            if v and v.Parent and slotCFs[v] then
                local dist = (v:GetPivot().Position - slotCFs[v].Position).Magnitude
                if dist > 15 then
                    table.insert(missed, v)
                end
            end
        end
        if #missed == 0 then break end
        Notify("Blix Hub", "Retrying "..#missed.." missed item(s) (pass "..pass..")...", 2)
        for _, v in ipairs(missed) do
            if not v or not v.Parent then continue end
            dragItemToSlot(v, slotCFs[v], 50)
        end
    end
end

local function getOwnedItems()
    local items = {}
    for _,v in pairs(workspace.LogModels:GetChildren()) do
        if v:IsA("Model") and v:FindFirstChild("Owner") and v.Owner.Value == LP then
            table.insert(items, v)
        end
    end
    for _,v in pairs(workspace.PlayerModels:GetChildren()) do
        if v:IsA("Model") and v:FindFirstChild("Owner") and v.Owner.Value == LP
        and v:FindFirstChild("WoodSection") then
            table.insert(items, v)
        end
    end
    return items
end

