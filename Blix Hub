-- shared kill logic
local killTarget = nil
local autoKillEnabled = false

local function flingKill(targetPlayer)
    local character = LP.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not targetPlayer or not targetPlayer.Character then return end
    local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end

    Notify("Blix Hub", "Killing: "..targetPlayer.Name, 2)

    -- TP directly onto the target so contact is guaranteed
    hrp.CFrame = CFrame.new(targetHRP.Position + Vector3.new(0, 2, 0))
    task.wait(0.3)

    -- Disable collision so we can pass through and fling
    for _, v in ipairs(character:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end

    -- Apply massive velocity to create a physics shockwave fling
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    task.wait(0.05)
    hrp.CFrame = CFrame.new(targetHRP.Position)
    hrp.AssemblyLinearVelocity = Vector3.new(1e6, 1e6, 1e6)

    task.wait(0.1)
    -- Also fling position into void for maximum effect
    local pos = hrp.Position
    hrp.CFrame = CFrame.new(pos.X + 1e6, pos.Y, pos.Z)

    task.wait(2)
    -- Restore collision so your character works again after respawn
    if LP.Character then
        for _, v in ipairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = true end
        end
    end
    Notify("Blix Hub", "Done!", 1.5)
end

