sTruckLoad:Toggle("Truck Touch Teleport", function(t)
    touchTpEnabled = t
    for _,c in pairs(touchTpConns) do pcall(function() c:Disconnect() end) end
    touchTpConns  = {}
    touchedModels = {}
    if not t then Notify("Blix Hub","Touch TP OFF",1.5); return end
    if not touchTpDestination then
        Notify("Blix Hub","Set a destination first!",3)
        touchTpEnabled = false; return
    end

    local truck = getPlayerTruck()
    if not truck then Notify("Blix Hub","No truck found! Spawn one first.",3); return end
    Notify("Blix Hub","Touch TP ON — drive into items to send them!",2)

    for _,part in pairs(truck:GetDescendants()) do
        if part:IsA("BasePart") then
            local conn = part.Touched:Connect(function(hit)
                if not touchTpEnabled or not touchTpDestination then return end
                local model = hit:FindFirstAncestorOfClass("Model")
                if not model or model == truck then return end
                if not model:FindFirstChild("Owner") then return end
                if model.Owner.Value ~= LP then return end
                if not model:FindFirstChild("WoodSection") then return end
                -- avoid firing twice for same model
                if touchedModels[model] then return end
                touchedModels[model] = true
                spawn(function()
                    local dest = touchTpDestination
                    -- TP player near item first so server accepts drag
                    pcall(function()
                        LP.Character.HumanoidRootPart.CFrame = model:GetPivot()
                    end)
                    task.wait(0.5)
                    for i = 1, 20 do
                        Drag:FireServer(model)
                        model:PivotTo(dest)
                        Drag:FireServer(model)
                        task.wait(0)
                    end
                    task.wait(1)
                    touchedModels[model] = nil
                end)
            end)
            table.insert(touchTpConns, conn)
        end
    end
end)

