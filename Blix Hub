        -- Pulse border color
        local pulse = (math.sin(t * 2) + 1) / 2
        local r = math.floor(60 + pulse * 40)
        local g = math.floor(120 + pulse * 80)
        stroke.Color = Color3.fromRGB(r, g, 255)
