            btn.Text = '⟶  Verify Key'
            btnGrad.Color = ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(60,120,255)),ColorSequenceKeypoint.new(1,Color3.fromRGB(20,50,180))})
            stroke.Color = Color3.fromRGB(80,160,255)
            statusTxt.Text = 'SYSTEM ONLINE  |  Waiting for key...'
            statusDot.BackgroundColor3 = Color3.fromRGB(0,220,120)
            btn.Active = true
        end
    end)
end

