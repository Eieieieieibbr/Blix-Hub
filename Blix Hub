local function acGetBiggestTree(treeClass)
    local trees = {}
    for region, classes in next, acTreeRegions do
        if table.find(classes, treeClass) then
            for _,v in next, region:GetChildren() do
                if v:IsA("Model") and v:FindFirstChild("Owner") and v:FindFirstChild("TreeClass") then
                    if v.TreeClass.Value == treeClass and (v.Owner.Value == nil or v.Owner.Value == LP) then
                        local mass, trunk = 0, nil
                        for _,p in next, v:GetChildren() do
                            if p:IsA("BasePart") then
                                if p:FindFirstChild("ID") and p.ID.Value == 1 then trunk = p end
                                mass = mass + p:GetMass()
                            end
                        end
                        table.insert(trees, {tree=v, trunk=trunk, mass=mass})
                    end
                end
            end
        end
    end
    table.sort(trees, function(a,b) return a.mass > b.mass end)
    return trees[1] or nil
end

local acTreeAddedConn = nil

local function acTreeListener(treeClass, callback)
    if acTreeAddedConn then acTreeAddedConn:Disconnect() end
    acTreeAddedConn = workspace.LogModels.ChildAdded:Connect(function(child)
        local owner = child:WaitForChild("Owner", 5)
        if owner and owner.Value == LP then
            local tc = child:WaitForChild("TreeClass", 5)
            if tc and tc.Value == treeClass then
                if acTreeAddedConn then acTreeAddedConn:Disconnect(); acTreeAddedConn = nil end
                callback(child)
            end
        end
    end)
end

local function bringTree(treeClass)
    getgenv().treestop = true
    getgenv().treeCut  = false

    local ok, axe = acGetBestAxe(treeClass)
    if not ok or not axe then
        Notify("Blix Hub", "No axe found in backpack!", 3)
        return
    end

    local treeData = acGetBiggestTree(treeClass)
    if not treeData then
        Notify("Blix Hub", "No "..treeClass.." tree found!", 2)
        return
    end

    local trunk = treeData.trunk
    if not trunk then
        Notify("Blix Hub", "Tree trunk not found!", 2)
        return
    end

    OldPos = acGetCFrame()

    acTreeListener(treeClass, function(log)
        log.PrimaryPart = log:FindFirstChild("WoodSection") or log.PrimaryPart
        getgenv().treeCut = true
        for i = 1, 60 do
            acDragModel(log, OldPos.Position)
            task.wait()
        end
    end)

    task.wait(0.15)

    task.spawn(function()
        repeat
            if not getgenv().treestop then break end
            acTP(trunk.CFrame)
            task.wait()
        until getgenv().treeCut
    end)

    task.wait()

    local cutEvent = treeData.tree:FindFirstChild("CutEvent") or treeData.tree:WaitForChild("CutEvent", 5)
    if not cutEvent then
        Notify("Blix Hub", "Tree has no CutEvent!", 2)
        return
    end

    repeat
        if not getgenv().treestop then break end
        pcall(acCutPart, cutEvent, 1, 0.3, axe, treeClass)
        task.wait()
    until getgenv().treeCut
        or not treeData.tree.Parent
        or treeData.tree:FindFirstChild("RootCut")
        or treeData.tree:FindFirstChild("InnerWood")
        or (trunk.BrickColor == BrickColor.new("Black"))

    task.wait(1)
    getgenv().treeCut  = false
    acTP(OldPos)
end

