    -- Save player position
    local savedCF = char.HumanoidRootPart.CFrame
    -- TP player to the model so server accepts drag events
    pcall(function() char.HumanoidRootPart.CFrame = model:GetPivot() end)
    task.wait(1.2)  -- wait longer so server registers new position
    -- Now repeatedly drag model to target while near it
    for i = 1, 40 do
        Drag:FireServer(model)
        model:PivotTo(targetCF)
        Drag:FireServer(model)
        task.wait(0.05)
    end
    -- Restore player position
    task.wait(0.2)
    pcall(function() char.HumanoidRootPart.CFrame = savedCF end)
end

