local function acTP(pos)
    if typeof(pos) == "CFrame" then
        pcall(function() LP.Character:SetPrimaryPartCFrame(pos) end)
    elseif typeof(pos) == "Vector3" then
        pcall(function() LP.Character:MoveTo(pos) end)
