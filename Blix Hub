local function acGetTools()
    local hum = LP.Character and LP.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum:UnequipTools() end
    local tools = {}
    for _,v in ipairs(LP.Backpack:GetChildren()) do
        if v.Name ~= "BlueprintTool" and v.Name ~= "Delete" and v.Name ~= "Undo" then
            table.insert(tools, v)
        end
    end
    return tools
end

local function acGetToolStats(tool)
    local toolName = (typeof(tool) == "string") and tool or tool.ToolName and tool.ToolName.Value or tool.Name
    local ok, stats = pcall(function()
        return require(ReplicatedStorage.AxeClasses["AxeClass_"..toolName]).new()
    end)
    if ok and stats then return stats end
    return {Damage=1, SwingCooldown=0.5}
end

local function acGetBestAxe(treeClass)
    local tools = acGetTools()
    if #tools == 0 then return false, nil end
    local best, bestDmg = nil, -1
    for _,v in ipairs(tools) do
        local stats = acGetToolStats(v)
        if treeClass == "LoneCave" and (v.ToolName and v.ToolName.Value == "EndTimesAxe" or v.Name == "End Times Axe") then
            return true, v
        end
        local dmg = stats.Damage or 1
        if stats.SpecialTrees and stats.SpecialTrees[treeClass] then
            dmg = stats.SpecialTrees[treeClass].Damage or dmg
        end
        if dmg > bestDmg then bestDmg = dmg; best = v end
    end
    return (best ~= nil), best
end

local function acCutPart(event, section, height, tool, treeClass)
    local stats = acGetToolStats(tool)
    if stats.SpecialTrees and stats.SpecialTrees[treeClass] then
        for k,v in next, stats.SpecialTrees[treeClass] do stats[k] = v end
    end
    ReplicatedStorage.Interaction.RemoteProxy:FireServer(event, {
        tool         = tool,
        faceVector   = Vector3.new(-1, 0, 0),
        height       = height or 0.3,
        sectionId    = section or 1,
        hitPoints    = stats.Damage or 1,
        cooldown     = stats.SwingCooldown or 0.5,
        cuttingClass = "Axe"
    })
end

