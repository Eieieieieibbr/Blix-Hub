local function StartMainScript()
-- ============================================================
-- Blix Hub | VLib UI | LT2 + Dark X Features
-- ============================================================
-- ============================================================
-- INLINE VLIB (self-contained, no external URL needed)
-- ============================================================
local VLib = (function()
    local lib = {}
    local UIS = game:GetService("UserInputService")
    local RS  = game:GetService("RunService")
    local LP2 = game:GetService("Players").LocalPlayer

    local function isTap(i)
        return i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch
    end
    local function isMove(i)
        return i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch
    end

    -- Builds the Blix Hub swirl logo from pure Roblox UI frames
    local function makeSwirl(parent, sz, zb)
        zb = zb or 1
        local c = Instance.new("Frame", parent)
        c.Size = UDim2.new(0, sz, 0, sz)
        c.BackgroundColor3 = Color3.fromRGB(8, 0, 20)
        c.BorderSizePixel = 0; c.ZIndex = zb
        Instance.new("UICorner", c).CornerRadius = UDim.new(1, 0)
        -- 5 swirl blades spaced 72° apart with a slight twist offset
        local cols = {
            Color3.fromRGB(40, 120, 255),
            Color3.fromRGB(20, 80, 200),
            Color3.fromRGB(80, 160, 255),
            Color3.fromRGB(15, 60, 200),
            Color3.fromRGB(50, 110, 240),
        }
        for i = 0, 4 do
            local bw = math.floor(sz * 0.28)
            local bh = math.floor(sz * 0.64)
            local blade = Instance.new("Frame", c)
            blade.Size = UDim2.new(0, bw, 0, bh)
            blade.Position = UDim2.new(0.5, -bw/2, 0.5, -bh/2)
            blade.BackgroundColor3 = cols[i + 1]
            blade.BackgroundTransparency = 0.1
            blade.BorderSizePixel = 0
            blade.Rotation = i * 72 + 18  -- 72° gaps + 18° twist = swirl
            blade.ZIndex = zb + 1
            Instance.new("UICorner", blade).CornerRadius = UDim.new(0.5, 0)
        end
        -- dark center dot to complete the vortex look
        local hs = math.floor(sz * 0.3)
        local hole = Instance.new("Frame", c)
        hole.Size = UDim2.new(0, hs, 0, hs)
        hole.Position = UDim2.new(0.5, -hs/2, 0.5, -hs/2)
        hole.BackgroundColor3 = Color3.fromRGB(5, 0, 14)
        hole.BorderSizePixel = 0; hole.ZIndex = zb + 3
        Instance.new("UICorner", hole).CornerRadius = UDim.new(1, 0)
        return c
    end

    function lib:Window(title, accent)
        local w = {}
        local tabList = {}
        local allDropdowns = {}
        accent = accent or Color3.fromRGB(30, 80, 200)

        local sg = Instance.new("ScreenGui")
        sg.Name = "Library"; sg.ResetOnSpawn = false
        sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        sg.DisplayOrder = 10000; sg.IgnoreGuiInset = true
        local _lp = false
        if not _lp then pcall(function() sg.Parent = game:GetService("CoreGui"); _lp = sg.Parent == game:GetService("CoreGui") end) end
