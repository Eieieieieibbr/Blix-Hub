local truckDupeGiver    = ""
local truckDupeReceiver = ""

sDupe:Textbox("Giver Username", function(v) truckDupeGiver = v end)
sDupe:Textbox("Receiver Username", function(v) truckDupeReceiver = v end)

local function isPointInsideTruck(point, boxCFrame, boxSize)
    local rel = boxCFrame:PointToObjectSpace(point)
    return math.abs(rel.X) <= boxSize.X / 2
       and math.abs(rel.Y) <= (boxSize.Y / 2 + 2)
       and math.abs(rel.Z) <= boxSize.Z / 2
end

sDupe:Button("► Dupe Truck", function()
    spawn(function()
        if truckDupeGiver == "" or truckDupeReceiver == "" then
            Notify("Blix Hub","Set both Giver and Receiver usernames first!",3); return
        end

        local char = LP.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then
            Notify("Blix Hub","No character found!",3); return
        end

        -- Find giver and receiver OriginSquares
        local GiveBaseOrigin, ReceiverBaseOrigin
        for _,v in pairs(workspace.Properties:GetDescendants()) do
            if v.Name == "Owner" then
                if tostring(v.Value) == truckDupeGiver   then GiveBaseOrigin     = v.Parent:FindFirstChild("OriginSquare") end
                if tostring(v.Value) == truckDupeReceiver then ReceiverBaseOrigin = v.Parent:FindFirstChild("OriginSquare") end
            end
        end
        if not GiveBaseOrigin     then Notify("Blix Hub","Giver base not found!",3); return end
        if not ReceiverBaseOrigin then Notify("Blix Hub","Receiver base not found!",3); return end

        local teleportedParts = {}
        local ignoredParts    = {}
        local didTruckTP      = false
        local truckOffset     = nil
        local doorHinge       = nil

        local function isPointInside(point, boxCF, boxSize)
            local rel = boxCF:PointToObjectSpace(point)
            return math.abs(rel.X) <= boxSize.X / 2
               and math.abs(rel.Y) <= (boxSize.Y / 2 + 2)
               and math.abs(rel.Z) <= boxSize.Z / 2
        end

        local function teleportTruck(truck)
            if didTruckTP then return end
            local truckMain = truck:FindFirstChild("Main")
            if not truckMain then return end
            local cf     = truckMain.CFrame
            local newPos = cf.Position - GiveBaseOrigin.Position + ReceiverBaseOrigin.Position
            truckOffset  = CFrame.new(newPos) * cf.Rotation
            truck:SetPrimaryPartCFrame(truckOffset)
            didTruckTP = true
        end

        -- Find the giver's truck in PlayerModels and sit in it
        for _,v in pairs(workspace.PlayerModels:GetDescendants()) do
            if v.Name == "Owner" and tostring(v.Value) == truckDupeGiver then
                if v.Parent:FindFirstChild("DriveSeat") then
                    local truck = v.Parent
                    Notify("Blix Hub","Sitting in truck...",2)

                    truck.DriveSeat:Sit(char.Humanoid)
                    repeat task.wait() truck.DriveSeat:Sit(char.Humanoid) until char.Humanoid.SeatPart

                    local modelCF, modelSize = truck:GetBoundingBox()

                    -- Build ignore list
                    for _,p in pairs(truck:GetDescendants()) do
                        if p:IsA("BasePart") then ignoredParts[p] = true end
                    end
                    for _,p in pairs(char:GetDescendants()) do
                        if p:IsA("BasePart") then ignoredParts[p] = true end
                    end

                    -- Cache DoorHinge for post-TP door open
                    pcall(function()
                        doorHinge = truck:FindFirstChild("PaintParts",true)
                            and truck.PaintParts:FindFirstChild("DoorLeft",true)
                            and truck.PaintParts.DoorLeft:FindFirstChild("ButtonRemote_Hinge")
                    end)

                    local sitPart = char.Humanoid.SeatPart
                    Notify("Blix Hub","Scanning items on truck...",2)

                    -- Spawn a coroutine per Main/WoodSection part on the truck
                    for _,part in ipairs(workspace:GetDescendants()) do
                        if part:IsA("BasePart") and not ignoredParts[part]
                           and (part.Name == "Main" or part.Name == "WoodSection") then
                            -- Skip items already welded to something else
                            local weld = part:FindFirstChild("Weld")
                            if weld and weld.Part1 and weld.Part1.Parent ~= part.Parent then continue end

                            task.spawn(function()
                                if not isPointInside(part.Position, modelCF, modelSize) then return end

                                -- Teleport truck exactly once
                                teleportTruck(truck)

                                local oldPos  = part.Position
                                local pCF     = part.CFrame
                                local newPos2 = pCF.Position - GiveBaseOrigin.Position + ReceiverBaseOrigin.Position
                                local target  = CFrame.new(newPos2) * pCF.Rotation

                                part.CFrame = target

                                table.insert(teleportedParts, {
                                    Instance    = part,
                                    OldPos      = oldPos,
                                    TargetCFrame = target,
                                })
                            end)
                        end
                    end

                    -- Eject from truck and open door
                    task.wait()
                    char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.wait(0.1)
                    pcall(function() sitPart:Destroy() end)
                    teleportTruck(truck) -- ensure truck moved even if no items found
                    didTruckTP = false   -- reset for next truck if loop continues

                    if doorHinge then
                        for i = 1, 10 do
                            ReplicatedStorage.Interaction.RemoteProxy:FireServer(doorHinge)
                        end
                    end
                end
            end
        end

        -- Retry loop: keep nudging items that didn't move far enough
        Notify("Blix Hub","Waiting for items to settle...",2)
        task.wait(5)

        local function doRetry(list)
            for _,data in ipairs(list) do
                local item = data.Instance
                if (char.HumanoidRootPart.Position - item.Position).Magnitude > 25 then
                    char.HumanoidRootPart.CFrame = item.CFrame
                    task.wait(0.1)
                end
                for i = 1, 50 do
                    Drag:FireServer(item.Parent)
                    task.wait(0.05)
                end
                item.CFrame = data.TargetCFrame
                task.wait(0.1)
            end
        end

        repeat
            task.wait(5)
            local retries = {}
            for _,data in ipairs(teleportedParts) do
                if (data.Instance.Position - data.OldPos).Magnitude < 25 then
                    table.insert(retries, data)
                end
            end
            if #retries > 0 then
                Notify("Blix Hub","Retrying "..#retries.." item(s)...",2)
                doRetry(retries)
            else
                break
            end
        until false

        Notify("Blix Hub","Truck Dupe complete!",3)
    end)
end)

