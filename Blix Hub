local function pa_colorDist(r1,g1,b1, r2,g2,b2)
    return (r1-r2)^2 + (g1-g2)^2 + (b1-b2)^2
end

local function pa_nearestColor(r,g,b)
    local best, bestDist = PA_PALETTE[1], math.huge
    for _,c in ipairs(PA_PALETTE) do
        local d = pa_colorDist(r,g,b, c.r,c.g,c.b)
        if d < bestDist then bestDist=d; best=c end
    end
    return best
end

local function pa_readImage(assetId, gridW, gridH)
    local pixels = {}
    local ok, img = pcall(function()
        return game:GetService("AssetService"):CreateEditableImageAsync("rbxassetid://"..assetId)
    end)
    if not ok or not img then
        Notify("Blix Hub","Could not load image. Check the asset ID.",3)
        return nil
    end
    local imgW, imgH = img.Size.X, img.Size.Y
    for py = 0, gridH-1 do
        pixels[py+1] = {}
        for px = 0, gridW-1 do
            local sx = math.floor(px / gridW * imgW)
            local sy = math.floor(py / gridH * imgH)
            local c  = img:ReadPixels(Vector2.new(sx,sy), Vector2.new(1,1))
            -- c is {r,g,b,a} in 0-1 range
            local r,g,b = math.floor((c[1] or 0)*255), math.floor((c[2] or 0)*255), math.floor((c[3] or 0)*255)
            local a = c[4] or 1
            if a < 0.1 then
                pixels[py+1][px+1] = nil -- transparent = skip
            else
                pixels[py+1][px+1] = pa_nearestColor(r,g,b)
            end
        end
    end
    img:Destroy()
    return pixels
end

local function pa_buildWall(pixels, gridW, gridH, pixelStuds, origin, isWall)
    local PlaceRemote = ReplicatedStorage.PlaceStructure.ClientPlacedStructure
    local total = 0
    local placed = 0
    for py=1,gridH do for px=1,gridW do if pixels[py][px] then total=total+1 end end end
    Notify("Blix Hub","Building "..total.." pixel(s)...",2)
    for py=1,gridH do
        for px=1,gridW do
            local col = pixels[py][px]
            if col then
                local xOff = (px-1)*pixelStuds
                local yOff = (gridH-py)*pixelStuds
                local cf
                if isWall then
                    -- build on a vertical wall facing you
                    cf = origin * CFrame.new(xOff, yOff, 0)
                else
                    -- build flat on the floor
                    cf = origin * CFrame.new(xOff, 0, yOff) * CFrame.Angles(-math.pi/2,0,0)
                end
                pcall(function()
                    repeat
                        task.wait(0)
                        PlaceRemote:FireServer("Wood Wall", cf, LP, nil, nil, true)
                    until false -- will be broken by server removing the pending model
                end)
                placed = placed + 1
                if placed % 10 == 0 then
                    Notify("Blix Hub","Placed "..placed.."/"..total,1)
                end
                task.wait(0.05)
            end
        end
    end
    Notify("Blix Hub","Build complete! "..placed.." pieces placed.",3)
    return placed
end

local function pa_exportJSON(pixels, gridW, gridH, pixelStuds, origin, isWall)
    local entries = {}
    for py=1,gridH do
        for px=1,gridW do
            local col = pixels[py][px]
            if col then
                local xOff = (px-1)*pixelStuds
                local yOff = (gridH-py)*pixelStuds
                local cf
                if isWall then
                    cf = origin * CFrame.new(xOff, yOff, 0)
                else
                    cf = origin * CFrame.new(xOff, 0, yOff) * CFrame.Angles(-math.pi/2,0,0)
                end
                local p = cf.Position
                local rx,ry,rz = cf:ToEulerAnglesXYZ()
                table.insert(entries, string.format(
                    '{"item":"Wood Wall","x":%.2f,"y":%.2f,"z":%.2f,"rx":%.4f,"ry":%.4f,"rz":%.4f,"r":%d,"g":%d,"b":%d,"color":"%s"}',
                    p.X,p.Y,p.Z, rx,ry,rz, col.r,col.g,col.b, col.name
                ))
            end
        end
    end
    local json = '{"version":1,"tool":"BlixHub","type":"PixelArt","structures":[\n'
              .. table.concat(entries, ",\n")
              .. "\n]}"
    local filename = "BlixHubPixelArt_"..tostring(os.time())..".json"
    pcall(function() writefile(filename, json) end)
    Notify("Blix Hub","Exported to "..filename.." ("..#entries.." pieces)",4)
    return filename
end

