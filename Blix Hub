    Notify("Blix Hub","[1/4] Checking server load lock...",2)
    while not ReplicatedStorage.LoadSaveRequests.ClientMayLoad:InvokeServer(LP) do task.wait(0) end
    Notify("Blix Hub","[2/4] Loading your base from slot "..slot.."...",2)
    task.spawn(function() ReplicatedStorage.LoadSaveRequests.RequestLoad:InvokeServer(slot,LP) end)
    local timeout = 0
    repeat task.wait(0) timeout=timeout+1 until workspace.Effects:FindFirstChild("StructureModel") or timeout>500
    Notify("Blix Hub","[3/4] Claiming free plot...",2)
    local p = getFreePlot()
    if p then
        for i=1,3 do
            task.spawn(function() ReplicatedStorage.PropertyPurchasing.ClientPurchasedProperty:FireServer(p,p.OriginSquare.Position) end)
            task.wait(0.1)
        end
    end
    Notify("Blix Hub","[4/4] Dupe done! Rejoining in 2s...",3)
    wait(2)
    spawn(function() LP:remove() end)
end

function MaxLandDupe()
    Notify("Blix Hub","Starting Max Land Dupe...",2)
    while not ReplicatedStorage.LoadSaveRequests.ClientMayLoad:InvokeServer(LP) do task.wait() end
    task.spawn(function() ReplicatedStorage.LoadSaveRequests.RequestLoad:InvokeServer(slot,LP) end)
    local p = getFreePlot()
    repeat task.wait() until workspace.Effects:FindFirstChild("StructureModel")
    if p then
        task.spawn(function() ReplicatedStorage.PropertyPurchasing.ClientPurchasedProperty:FireServer(p,p.OriginSquare.CFrame.p+Vector3.new(0,3,0)) end)
        wait(0.5)
